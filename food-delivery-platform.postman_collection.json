{
  "info": {
    "_postman_id": "872b4b78-aeb2-4550-8ec0-09fe56d214e8",
    "name": "Food Delivery Platform - Service Tests",
    "description": "Teacher-style collection for the implemented services. IDs are stored in collection variables. This targets services directly because the current gateway module does not expose routing yet.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.collectionVariables.set('runId', String(Date.now()));"
        ]
      }
    }
  ],
  "variable": [
    { "key": "customersBaseUrl", "value": "http://localhost:8082" },
    { "key": "restaurantsBaseUrl", "value": "http://localhost:8083" },
    { "key": "driversBaseUrl", "value": "http://localhost:8084" },
    { "key": "ordersBaseUrl", "value": "http://localhost:8081" },
    { "key": "missingId", "value": "00000000-0000-0000-0000-000000000000" },
    { "key": "seedCustomerId", "value": "11111111-1111-1111-1111-111111111111" },
    { "key": "seedRestaurantId", "value": "33333333-3333-3333-3333-333333333333" },
    { "key": "seedDriverId", "value": "55555555-5555-5555-5555-555555555551" },
    { "key": "seedOrderId", "value": "66666666-6666-6666-6666-666666666666" },
    { "key": "pizzaMenuItemId", "value": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaa1" },
    { "key": "veggieMenuItemId", "value": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaa2" },
    { "key": "customerCrudId", "value": "" },
    { "key": "restaurantCrudId", "value": "" },
    { "key": "driverCrudId", "value": "" },
    { "key": "orderCrudId", "value": "" }
