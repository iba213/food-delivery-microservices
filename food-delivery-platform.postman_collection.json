  "item": [
    {
      "name": "Customers Service",
      "item": [
        {
          "name": "List Customers",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(200);","pm.expect(Array.isArray(pm.response.json())).to.eql(true);"] } }],
          "request": { "method": "GET", "header": [], "url": "{{customersBaseUrl}}/api/customers" }
        },
        {
          "name": "Get Customer By Seed Id",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(200);","pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('seedCustomerId'));"] } }],
          "request": { "method": "GET", "header": [], "url": "{{customersBaseUrl}}/api/customers/{{seedCustomerId}}" }
        },
        {
          "name": "Create Customer",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.expect([200,201]).to.include(pm.response.code);","const j=pm.response.json();","pm.expect(j.id).to.be.ok;","pm.collectionVariables.set('customerCrudId', j.id);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Customer {{runId}}\",\n  \"email\": \"customer{{runId}}@example.com\",\n  \"phone\": \"514555{{runId}}\",\n  \"street\": \"12 Oak Street\",\n  \"city\": \"Montreal\",\n  \"province\": \"Quebec\",\n  \"postalCode\": \"H3A1A1\"\n}" },
            "url": "{{customersBaseUrl}}/api/customers"
          }
        },
        {
          "name": "Create Customer - Invalid Email (400)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(400);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Bad Customer\",\n  \"email\": \"bad-email\",\n  \"phone\": \"5145550000\",\n  \"street\": \"1 Test St\",\n  \"city\": \"Montreal\",\n  \"province\": \"Quebec\",\n  \"postalCode\": \"H1H1H1\"\n}" },
            "url": "{{customersBaseUrl}}/api/customers"
          }
        },
        {
          "name": "Create Customer - Duplicate Email (409)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(409);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Duplicate Alice\",\n  \"email\": \"alice@example.com\",\n  \"phone\": \"5145550000\",\n  \"street\": \"1 Test St\",\n  \"city\": \"Montreal\",\n  \"province\": \"Quebec\",\n  \"postalCode\": \"H1H1H1\"\n}" },
            "url": "{{customersBaseUrl}}/api/customers"
          }
        },
        {
          "name": "Update Created Customer",
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": ["if (!pm.collectionVariables.get('customerCrudId')) throw new Error('Run Create Customer first.');"] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(200);","pm.expect(pm.response.json().name).to.include('Updated');"] } }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Customer {{runId}} Updated\",\n  \"email\": \"customer{{runId}}.updated@example.com\",\n  \"phone\": \"5145559999\",\n  \"street\": \"500 Updated Street\",\n  \"city\": \"Montreal\",\n  \"province\": \"Quebec\",\n  \"postalCode\": \"H2H2H2\"\n}" },
            "url": "{{customersBaseUrl}}/api/customers/{{customerCrudId}}"
          }
        },
        {
          "name": "Get Customer - Not Found (404)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(404);"] } }],
          "request": { "method": "GET", "header": [], "url": "{{customersBaseUrl}}/api/customers/{{missingId}}" }
        },
        {
          "name": "Delete Created Customer",
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": ["if (!pm.collectionVariables.get('customerCrudId')) throw new Error('Run Create Customer first.');"] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(204);"] } }
          ],
          "request": { "method": "DELETE", "header": [], "url": "{{customersBaseUrl}}/api/customers/{{customerCrudId}}" }
        }
      ]
    },
